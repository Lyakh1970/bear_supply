# Скопируйте как .env и заполните. В git коммитить только этот пример (без секретов).

# Telegram (на дроплете используется BEAR_SUPPLY_TOKEN)
BEAR_SUPPLY_TOKEN=your_bot_token_from_BotFather
BEAR_SUPPLY_GROUP_ID=-5118688028

# Пути
BEAR_SUPPLY_DOWNLOAD_DIR=/opt/bear_supply/uploads
BEAR_SUPPLY_TOKEN_JSON=/opt/bear_supply/creds/token.json

# Google
BEAR_SUPPLY_SHEET_ID=your_google_sheet_id
BEAR_SUPPLY_WORKSHEET_NAME=Purchases_Log
BEAR_SUPPLY_DRIVE_FOLDER_ID=your_drive_folder_id_or_empty

# Supplier → ключ из листа Suppliers (чтобы колонка Platform не давала #N/A). JSON.
# BEAR_SUPPLY_SUPPLIER_ALIASES={"Amazon":"amazon.pl","Amazon ES":"amazon.es"}

# Значения по умолчанию для Category и Project (если не указаны в подписи) — для Report_Key
# BEAR_SUPPLY_DEFAULT_CATEGORY=IT Hardware
# BEAR_SUPPLY_DEFAULT_PROJECT=General

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (Digital Ocean Managed Database)
# ─────────────────────────────────────────────────────────────────────────────
# Вариант 1: Полный URL подключения (рекомендуется)
# DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# Вариант 2: Отдельные параметры
# DB_HOST=your-db-cluster.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=defaultdb
# DB_USER=doadmin
# DB_PASSWORD=your_password
# DB_SSLMODE=require
