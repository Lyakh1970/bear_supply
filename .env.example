# Bear Supply Bot - Environment Variables
# Copy as .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────────────────────
BEAR_SUPPLY_TOKEN=your_bot_token_from_BotFather
BEAR_SUPPLY_GROUP_ID=-5118688028

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (Digital Ocean Managed Database) - PRIMARY STORAGE
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# Nextcloud - FILE STORAGE (cloud.bearcloud.one)
# ─────────────────────────────────────────────────────────────────────────────
NEXTCLOUD_BASE_URL=https://cloud.bearcloud.one
NEXTCLOUD_USERNAME=bearbot
NEXTCLOUD_PASSWORD=your_app_password
NEXTCLOUD_BASE_FOLDER=Documents/BearBox Docs/Finance
NEXTCLOUD_SHARE_PASSWORD=BearBox2026!

# ─────────────────────────────────────────────────────────────────────────────
# Google Sheets via Apps Script Web App - UI LAYER
# ─────────────────────────────────────────────────────────────────────────────
# Deploy Apps Script as Web App and paste the URL here
# Example: https://script.google.com/macros/s/AKfycbw.../exec
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ─────────────────────────────────────────────────────────────────────────────
# Paths
# ─────────────────────────────────────────────────────────────────────────────
BEAR_SUPPLY_DOWNLOAD_DIR=/opt/bear_supply/uploads

# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────
# BEAR_SUPPLY_DEFAULT_CATEGORY=IT Hardware
# BEAR_SUPPLY_DEFAULT_PROJECT=General
# BEAR_SUPPLY_SUPPLIER_ALIASES={"Amazon":"amazon.pl","Amazon ES":"amazon.es"}

# ─────────────────────────────────────────────────────────────────────────────
# LEGACY (deprecated - kept for reference, not used in v3)
# ─────────────────────────────────────────────────────────────────────────────
# BEAR_SUPPLY_TOKEN_JSON=/opt/bear_supply/creds/token.json
# BEAR_SUPPLY_SHEET_ID=your_google_sheet_id
# BEAR_SUPPLY_WORKSHEET_NAME=Purchases_Log
# BEAR_SUPPLY_DRIVE_FOLDER_ID=your_drive_folder_id
